# ============================================================
# DWRS Backend — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_ENV=development          # development | staging | production
APP_SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=false
LOG_LEVEL=INFO

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://dwrs_user:password@localhost:5432/dwrs_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
SESSION_TTL_SECONDS=3600

# --- JWT (RS256 — generate with: openssl genrsa -out private.pem 4096) ---
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption (AES-256 for PII fields) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here
AADHAAR_SALT=your-random-64-char-salt-here

# --- UIDAI Aadhaar API ---
UIDAI_AUTH_URL=https://developer.uidai.gov.in/uidauthprod/2.5
UIDAI_AUA_CODE=your-aua-code
UIDAI_ASA_CODE=your-asa-code
UIDAI_LICENSE_KEY=your-license-key
UIDAI_CERT_PATH=./certs/uidai.pem
UIDAI_PRIVATE_KEY_PATH=./certs/aua_private.p12

# --- AWS ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key          # Use IAM roles in production
AWS_SECRET_ACCESS_KEY=your-secret-key      # Use IAM roles in production

# S3
S3_BUCKET_PHOTOS=dwrs-worker-photos-prod
S3_BUCKET_DOCUMENTS=dwrs-worker-docs-prod
S3_PRESIGNED_URL_EXPIRY=3600

# AWS Rekognition
REKOGNITION_COLLECTION_ID=dwrs-faces-prod
FACE_MATCH_THRESHOLD=85.0                  # Minimum similarity % for face match

# --- Kafka / Event Bus ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT          # SASL_SSL in production
KAFKA_SASL_MECHANISM=                      # SCRAM-SHA-256 in production
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_TOPIC_PREFIX=dwrs.

# --- Elasticsearch / OpenSearch ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_AUDIT=dwrs-audit-logs
OPENSEARCH_URL=                            # AWS OpenSearch endpoint in production

# --- SMS / OTP (Twilio) ---
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+91XXXXXXXXXX
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3

# --- Risk Scoring ---
RISK_LOW_THRESHOLD=40
RISK_MEDIUM_THRESHOLD=60
OFFICER_MAX_DAILY_REGISTRATIONS=15
OFFICER_BURST_WINDOW_MINUTES=30
OFFICER_BURST_MAX_COUNT=5
OFFLINE_SYNC_MAX_AGE_HOURS=72
OFFICER_TRUST_LOW_THRESHOLD=0.40
OFFICER_TRUST_SUSPEND_THRESHOLD=0.25
GEO_MAX_ACCURACY_METERS=200
GEO_ADDRESS_MAX_DISTANCE_KM=2.0
RANDOM_AUDIT_PERCENTAGE=10

# --- Celery (Background Jobs) ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TIMEZONE=Asia/Kolkata

# --- Monitoring ---
SENTRY_DSN=
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# --- Geolocation ---
GOOGLE_MAPS_API_KEY=                       # For district boundary data

# --- Audit Chain ---
AUDIT_CHAIN_GENESIS_HASH=GENESIS
AUDIT_CHAIN_VERIFY_CRON=0 2 * * *         # Nightly at 2 AM

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_OFFICER_PER_MINUTE=30
